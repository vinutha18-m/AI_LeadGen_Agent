# ── Bark.com Credentials ──────────────────────────────────────────────────────
BARK_EMAIL=your_bark_email@example.com
BARK_PASSWORD=your_bark_password

# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Agent Config (optional overrides) ────────────────────────────────────────
DEMO_MODE=true          # Set to false to run against real Bark.com
HEADLESS=false          # Set to true for CI/server environments
SCORE_THRESHOLD=0.8     # Leads above this score get a pitch generated
MAX_LEADS=20            # Max leads to scrape per run
